# Code Agent Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ============================================================
# CHOOSE YOUR PRIMARY PROVIDER
# ============================================================
AI_PROVIDER=gemini

# ============================================================
# FREE API KEYS — Get them here:
# ============================================================

# Google Gemini (RECOMMENDED — best quality, free)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (FASTEST inference, free tier)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (many free models via one API)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Together AI (free tier with Llama models)
# Get key: https://api.together.xyz
TOGETHER_API_KEY=your_together_api_key_here

# Cohere (free tier with Command-R)
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Mistral AI (free tier)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace (free inference API)
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ============================================================
# Ollama (LOCAL — completely free, no key needed)
# Install: https://ollama.ai
# Pull model: ollama pull llama3.2
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# AGENT SETTINGS (optional)
# ============================================================

# Max tool-calling iterations per conversation turn (default: 50)
MAX_ITERATIONS=50

# Shell command timeout in seconds (default: 30)
BASH_TIMEOUT=30

# Max tokens in response (default: 8192)
MAX_TOKENS=8192

# Temperature 0.0-1.0 (default: 0.7)
TEMPERATURE=0.7

# Safe mode: ask before file writes and bash commands (default: false)
# SAFE_MODE=true

# Verbose: show full tool outputs (default: false)
# VERBOSE=true

# Override model (otherwise uses provider default)
# AI_MODEL=gemini-2.0-flash-exp
